    {
      "id": "script",
      "type": "llm.generate",
      "params": {
        "model": "anthropic/claude-sonnet-4.5",
        "system": "Bạn là copywriter cao cấp cho các thương hiệu nước hoa xa xỉ Việt Nam. Nhiệm vụ: từ tên sản phẩm được cho, viết 1 script thuyết minh video quảng cáo dài 60-80 từ, giọng văn sang trọng, gợi cảm, tinh tế, có mở đầu cuốn hút và kết thúc mời gọi trải nghiệm. Chỉ trả về script, không giải thích thêm.",
        "temperature": 0.8
      },
      "position": { "x": 300, "y": 0 }
    },
    {
      "id": "voice",
      "type": "vbee.tts",
      "params": {
        "voiceCode": "sg_female_thaotrinh_full_48k-fhg",
        "speed": 0.95,
        "format": "mp3"
      },
      "position": { "x": 600, "y": -120 }
    },
    {
      "id": "vid_prompt",
      "type": "llm.transform",
      "params": {
        "instruction": "Từ script quảng cáo nước hoa cao cấp này, viết 1 video prompt bằng tiếng Anh (tối đa 50 từ) mô tả cảnh cinematic luxury: ánh sáng vàng ấm, chuyển động camera chậm rãi và sang trọng, chai nước hoa lấp lánh, không khí xa xỉ. Chỉ trả về prompt, không giải thích.",
        "model": "anthropic/claude-sonnet-4.5",
        "temperature": 0.4
      },
      "position": { "x": 600, "y": 120 }
    },
    {
      "id": "video",
      "type": "fal.video",
      "params": {
        "modelId": "fal-ai/veo3",
        "duration": 8,
        "aspectRatio": "9:16"
      },
      "position": { "x": 900, "y": 120 }
    },
    {
      "id": "final",
      "type": "video.compose",
      "params": {
        "width": 1080,
        "height": 1920,
        "fit": "cover",
        "loopVideo": true,
